# Copy to .env.local (never commit secrets)

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Canonical public URL (metadata, sitemap, member “Back to Website”). Same origin when marketing + portal share one deploy.
NEXT_PUBLIC_PUBLIC_SITE_URL=http://localhost:3000

# Contact form (Resend). Use a verified domain for CONTACT_FROM_EMAIL in production.
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Optional: Sanity (when wired)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
LWM_SANITY_TOKEN=
