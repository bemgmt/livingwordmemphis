# Copy to .env.local (never commit secrets)

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Canonical public URL (metadata, sitemap, member “Back to Website”). Same origin when marketing + portal share one deploy.
NEXT_PUBLIC_PUBLIC_SITE_URL=http://localhost:3000

# Contact form (Resend). Use a verified domain for CONTACT_FROM_EMAIL in production.
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Embedded Sanity Studio (/admin/studio) — must match standalone studio in ../sanity (SANITY_STUDIO_* there).
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Optional: read token for server-side GROQ (not required for the studio UI)
LWM_SANITY_TOKEN=

# OpenAI — powers the member Study Assistant
OPENAI_API_KEY=

# API.Bible — approved Bible reading in the member portal
API_BIBLE_KEY=
